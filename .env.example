# ============================================================
# StadiumIQ Environment Configuration
# Copy to .env and modify as needed
# All USE_* flags default to false for fully offline development
# ============================================================

# --- Application ---
APP_ENV=development
PORT=8080
CORS_ORIGINS=http://localhost:5173

# --- Google Cloud Project ---
GCP_PROJECT_ID=your-gcp-project-id

# --- Feature Flags (set to true to enable GCP services) ---
USE_GEMINI=false
USE_FIRESTORE=false
USE_BIGQUERY=false
USE_PUBSUB=false

# --- Vertex AI / Gemini ---
GEMINI_MODEL=gemini-1.5-flash
GEMINI_LOCATION=us-central1

# --- Firestore ---
FIRESTORE_DATABASE=(default)

# --- BigQuery ---
BIGQUERY_DATASET=stadium_analytics

# --- Pub/Sub ---
PUBSUB_TOPIC_ALERTS=stadium-alerts
PUBSUB_TOPIC_SCHEDULE=stadium-schedule-changes

# --- Rate Limits ---
RATE_LIMIT_INSIGHTS=10/minute
RATE_LIMIT_SCHEDULE=20/minute
RATE_LIMIT_CROWD=30/minute
RATE_LIMIT_ANALYTICS=15/minute
